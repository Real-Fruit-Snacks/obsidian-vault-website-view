{
  "name": "obsidian-vault-website-view",
  "version": "1.0.5",
  "description": "View your Obsidian vault as an interactive website inside the app.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "website",
    "preview",
    "view"
  ],
  "author": "Real-Fruit-Snacks",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.11.18",
    "esbuild": "^0.19.11",
    "jsdom": "^29.1.1",
    "obsidian": "^1.4.16",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
